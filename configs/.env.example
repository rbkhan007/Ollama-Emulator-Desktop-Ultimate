# PostgreSQL Database Configuration
# Supports local PostgreSQL, NeonDB, Supabase, or any Postgres-compatible service.

# ── Option A: NeonDB (recommended for production) ─────────────
# Get connection string from https://console.neon.tech → Project → Connection Details
# Use the pooled endpoint (-pooler) for connection pooling:
#   postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
# OLLAMA_EMU_DATABASE_URL=postgresql://neondb_owner:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Option B: Individual env vars (local dev) ─────────────────
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=ollamaemu
PGPASSWORD=ollamaemu
PGDATABASE=ollamaemu

# ── Option C: Single connection string (local dev) ────────────
# Takes precedence over PG* vars when set.
# OLLAMA_EMU_DATABASE_URL=postgresql://ollamaemu:ollamaemu@127.0.0.1:5432/ollamaemu

# Server Config
OLLAMA_EMU_BIND=127.0.0.1
OLLAMA_EMU_PORT=11434

# Provider Config
OLLAMA_EMU_PROVIDER=openrouter
OLLAMA_EMU_API_KEY=sk-or-v1-your-key-here

# pgvector Configuration
# Embedding backend: "tfidf" (built-in), "sentence-transformers" or "st", "openai" or "api"
OLLAMA_EMU_EMBEDDING_BACKEND=tfidf
# Embedding dimension (must match model: MiniLM=384, text-embedding-3-small=1536)
OLLAMA_EMU_EMBEDDING_DIM=384
# Model name (for sentence-transformers or OpenAI-compatible API)
OLLAMA_EMU_EMBEDDING_MODEL=
# For OpenAI-compatible embedding API
OLLAMA_EMU_EMBEDDING_API_URL=
OLLAMA_EMU_EMBEDDING_API_KEY=

# Chunking Configuration
OLLAMA_EMU_CHUNK_SIZE=512
OLLAMA_EMU_CHUNK_OVERLAP=64

# RAG Search Configuration
OLLAMA_EMU_RAG_TOP_K=5
OLLAMA_EMU_RAG_MIN_SIM=0.0
OLLAMA_EMU_RAG_HYBRID_ALPHA=0.7

# Vector Index Configuration
# Index type: "hnsw" (faster, more memory) or "ivfflat" (slower, less memory)
OLLAMA_EMU_RAG_INDEX_TYPE=hnsw
# HNSW parameters
OLLAMA_EMU_RAG_HNSW_M=16
OLLAMA_EMU_RAG_HNSW_EF_CONSTRUCTION=200
# IVFFlat parameters
OLLAMA_EMU_RAG_IVFFLAT_LISTS=100

# ACL & Security Configuration
OLLAMA_EMU_RATE_LIMIT=60
OLLAMA_EMU_RATE_WINDOW=60
OLLAMA_EMU_SESSION_EXPIRY=720
OLLAMA_EMU_MAX_SESSIONS=5
OLLAMA_EMU_ADMIN_EMAIL=
OLLAMA_EMU_IP_BLOCKLIST=
OLLAMA_EMU_IP_ALLOWLIST=

# Payment (Lemon Squeezy — primary provider, global, tax handled)
# Dashboard: https://app.lemonsqueezy.com — create a store, products & variants,
# then a webhook pointing at: <APP_URL>/api/payment/lemonsqueezy/webhook
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
# Variant IDs (one per plan) — find under each product's variant in the dashboard
LEMON_SQUEEZY_VARIANT_WEB_PRO=
LEMON_SQUEEZY_VARIANT_DESKTOP_PRO=
LEMON_SQUEEZY_VARIANT_MOBILE_ULTIMATE=

# SMTP Configuration (for sending license keys via email)
SMTP_SENDER=noreply@ollamomui.com
SMTP_PASSWORD=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# App URL (used for payment redirect URLs)
APP_URL=http://localhost:11434

# Custom SSL / HTTPS
# Paths to certificate files (only needed for self-hosted SSL termination)
# SSL_KEYFILE=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# SSL_CERTFILE=/etc/letsencrypt/live/yourdomain.com/fullchain.pem

# Set to "false" to allow cookies over HTTP (development only)
COOKIE_SECURE=true

# Set to "true" to disable all rate limiting (useful for local dev/testing)
OLLAMA_EMU_DISABLE_RATE_LIMIT=false

# Cloudflare Tunnel token (for exposing local server via Cloudflare Tunnel)
# CLOUDFLARE_TUNNEL_TOKEN=
