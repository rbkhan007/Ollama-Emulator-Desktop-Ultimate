# ═══════════════════════════════════════════════════════════════
# OllamoMUI – Production Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# NEVER commit secrets to version control.

# ── PostgreSQL (NeonDB) ──────────────────────────────────────
# Primary: single connection string (takes precedence over PG* vars).
# NeonDB connection string — get from https://console.neon.tech (Project → Connection Details)
# Use the pooled connection string (ends with -pooler) for transaction mode:
#   postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
OLLAMA_EMU_DATABASE_URL=postgresql://neondb_owner:your-neondb-password@ep-raspy-union-atp5rc1o-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Fallback: individual PG* vars (used only if OLLAMA_EMU_DATABASE_URL is empty)
# PGHOST=ep-raspy-union-atp5rc1o.us-east-1.aws.neon.tech
# PGPORT=5432
# PGUSER=neondb_owner
# PGPASSWORD=your-neondb-password
# PGDATABASE=neondb
# PGSSLMODE=require

# ── Server ──────────────────────────────────────────────────
OLLAMA_EMU_BIND=0.0.0.0
OLLAMA_EMU_PORT=11434
# OLLAMA_EMU_DISABLE_RATE_LIMIT=1  # Enable rate limiting by default for production

# ── Provider (default LLM) ─────────────────────────────────
OLLAMA_EMU_PROVIDER=openrouter
OLLAMA_EMU_API_KEY=sk-or-v1-your-key-here

# ── Embedding ──────────────────────────────────────────────
OLLAMA_EMU_EMBEDDING_BACKEND=tfidf
OLLAMA_EMU_EMBEDDING_DIM=384

# ── SSLCommerz (Payment Gateway) ───────────────────────────
# Get credentials from: https://sslcommerz.com
# Sandbox: https://sandbox.sslcommerz.com
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password

# ── SMTP (License Email Delivery) ──────────────────────────
SMTP_SENDER=noreply@ollamomui.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── App URL (used for payment redirects & CORS) ────────────
APP_URL=https://api.ollamomui.com
