# ═══════════════════════════════════════════════════════════════
# OllamoMUI Frontend — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Database (NeonDB / PostgreSQL) ──────────────────────────
# Frontend does NOT connect to PostgreSQL directly.
# If using Vercel Postgres (powered by Neon), set in Vercel dashboard:
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/db?sslmode=require
# DATABASE_URL="postgresql://ollamaemu:postgres@127.0.0.1:5432/ollamaemu"

# ── Backend API ──────────────────────────────────────────────
# Backend API base URL (set to your deployed backend, e.g. https://api.ollamomui.com)
# If empty, relative URLs like /api/... are used (works when served via same-domain proxy
# via next.config.js rewrites, or when frontend & backend are on the same domain).
# For standalone frontend deployment (Vercel), set this to the backend's public URL:
# NEXT_PUBLIC_API_BASE=https://api.ollamomui.com
NEXT_PUBLIC_API_BASE=

# ── Site & SEO ───────────────────────────────────────────────
# Canonical production URL. Defaults to VERCEL_PROJECT_PRODUCTION_URL.
# NEXT_PUBLIC_SITE_URL=https://ollamomui.com

# Base path (for GH Pages org subpath deployment)
# NEXT_PUBLIC_BASE_PATH=/ollamomui

# Free-tier gateway domain (defaults to SITE_DOMAIN)
# NEXT_PUBLIC_FREETIER_DOMAIN=ollamomui.com

# ── Payment Links (Stripe) ───────────────────────────────────
# Create products at https://dashboard.stripe.com/products and paste the payment links.
# NEXT_PUBLIC_STRIPE_WEB_PRO=https://buy.stripe.com/your_web_pro_link
# NEXT_PUBLIC_STRIPE_DESKTOP_PRO=https://buy.stripe.com/your_desktop_pro_link
# NEXT_PUBLIC_STRIPE_MOBILE_ULTIMATE=https://buy.stripe.com/your_mobile_ultimate_link
