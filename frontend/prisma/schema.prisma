// OllamaEmu — Prisma Schema (PostgreSQL + pgvector)
// Run: npx prisma migrate dev --name init
// Run: npx prisma generate

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Providers ──────────────────────────────────────────
model Provider {
  name          String   @id
  url           String?
  modelsUrl     String?  @map("models_url")
  authType      String?  @map("auth_type")
  defaultModel  String?  @map("default_model")
  freeHeuristic String?  @map("free_heuristic")
  type          String?
  apiKey        String?  @map("api_key")

  @@map("providers")
}

// ── Auth ───────────────────────────────────────────────
model User {
  email        String    @id
  passwordHash String    @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  sessions     Session[]

  @@map("users")
}

model Session {
  token     String   @id
  email     String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [email], references: [email])

  @@map("sessions")
}

// ── RAG (Retrieval-Augmented Generation) ───────────────
model RagDocument {
  id         String   @id
  filename   String
  fileHash   String   @map("file_hash")
  chunkCount Int      @default(0) @map("chunk_count")
  collection String   @default("default")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  chunks     RagChunk[]

  @@map("rag_documents")
}

model RagChunk {
  id         String      @id
  docId      String      @map("doc_id")
  chunkIndex Int         @map("chunk_index")
  content    String
  tokens     Json        @default("[]")
  embedding  Unsupported("vector(384)")?
  document   RagDocument @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([docId])
  @@map("rag_chunks")
}

model RagFts {
  id      Int    @id @default(autoincrement())
  docId   String @map("doc_id")
  content Unsupported("tsvector")

  @@index([content], type: Gin)
  @@map("rag_fts")
}

// ── Memory System ──────────────────────────────────────
model MemoryMessage {
  id        String   @id
  role      String
  content   String
  model     String   @default("")
  provider  String   @default("")
  sessionId String   @default("default") @map("session_id")
  tokens    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  flushed   Boolean  @default(false)

  @@index([sessionId])
  @@index([createdAt])
  @@map("memory_messages")
}

model MemoryFact {
  id         String   @id
  fact       String
  source     String   @default("")
  importance String   @default("normal")
  sessionId  String   @default("default") @map("session_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("memory_facts")
}

model MemorySummary {
  id           String   @id
  sessionId    String   @map("session_id")
  summary      String
  messageCount Int      @default(0) @map("message_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("memory_summaries")
}

model MemorySession {
  id           String   @id
  name         String   @default("")
  model        String   @default("")
  provider     String   @default("")
  messageCount Int      @default(0) @map("message_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  @@map("memory_sessions")
}
