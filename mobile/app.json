{
  "expo": {
    "name": "OllamaEmu",
    "slug": "ollama-emu-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ollamaemu",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0d0d1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ollamaemu.app"
    },
    "android": {
      "package": "com.ollamaemu.app",
      "adaptiveIcon": {
        "backgroundColor": "#0d0d1a"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6eda916e-e96f-4a29-8e38-e8605b42b56c"
      }
    },
    "owner": "rhavex"
  }
}
